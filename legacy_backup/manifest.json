{
  "name": "PINMAP",
  "short_name": "PINMAP",
  "description": "A social map for saving and sharing the places that matter to you. Drop pins, add hashtags, and discover locations shared by others.",
  "start_url": "/",
  "scope": "/",
  "display": "standalone",
  "orientation": "portrait",
  "background_color": "#1b4332",
  "theme_color": "#2e7d32",
  "lang": "en-US",
  "dir": "ltr",
  "categories": [
    "navigation",
    "travel",
    "social",
    "outdoor",
    "lifestyle"
  ],
  "icons": [
    {
      "src": "./icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "./icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "maskable"
    },
    {
      "src": "./icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "./icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable"
    }
  ],
  "shortcuts": [
    {
      "name": "Add a Pin",
      "short_name": "Add Pin",
      "description": "Drop a new pin on the map",
      "url": "/?action=add",
      "icons": [{ "src": "./icon-192.png", "sizes": "192x192" }]
    },
    {
      "name": "My Pins",
      "short_name": "My Pins",
      "description": "View all your saved pins",
      "url": "/?action=mine",
      "icons": [{ "src": "./icon-192.png", "sizes": "192x192" }]
    },
    {
      "name": "Search",
      "short_name": "Search",
      "description": "Search pins by hashtag",
      "url": "/?action=search",
      "icons": [{ "src": "./icon-192.png", "sizes": "192x192" }]
    }
  ],
  "prefer_related_applications": false,
  "display_override": ["standalone", "minimal-ui"],
  "handle_links": "preferred",
  "launch_handler": {
    "client_mode": "focus-existing"
  }
}
